{
  "version": 4,
  "naming_template": "{point.category}/{point.id}_{point.name}_{photo.taken_at:%Y%m%d_%H%M%S}{photo.source_path.suffix}",
  "allowed_extensions": [
    ".jpg",
    ".jpeg",
    ".png",
    ".gif",
    ".bmp",
    ".tiff",
    ".webp"
  ],
  "duplicate_strategy": "block",
  "archive_action": "move",
  "archive_dir": "archive",
  "photo_dir": "photos",
  "notes_json": "notes.json",
  "points_csv": "points.csv",
  "default_author": "user"
}